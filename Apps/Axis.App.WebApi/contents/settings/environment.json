{
  "Paths": {
    "Base": "",
    "Service": "service",
    "Database": "contents/databases",
    "Facial": "contents/identities"
  },
  "Database": {
    "ProviderName": "PostgreSql",
    "NamingConvention": "SnakeCase",
    "Migration": true,
    "OpeningIdentifier": "\"",
    "ClosingIdentifier": "\""
  },
  "WebToken": {
    "Identity": {
      "ClaimsIdentity": {
        "UserIdClaimType": "userid",
        "UserNameClaimType": "username"
      },
      "Password": {
        "RequireDigit": false,
        "RequiredLength": true,
        "RequireNonAlphanumeric": false,
        "RequireUppercase": false,
        "RequireLowercase": false,
      }
    },
    "Jwt": {
      "NameClaimType": "username",
      "ValidIssuer": "axis.io",
      "Audience": "axis.io",
      "Key": "VjajaEyIchihVYpHupKaITOFiaCaGuvHvdrapLvEbxgMiavYLQpLFaHyUAgHwaqSQaaliaTcbnNatSmmWBKgRcyb"
    }
  },
  "Plugins": {
    "Path": "contents/plugins",
    "PreferSharedTypes": true,
    "IsLazyLoaded": true,
    "IsUnloadable": true,
    "EnableHotReload": true
  },
  "Swagger": {
    "v1": {
      "Title": "Axis",
      "Version": "v1",
      "Description": "Axis API"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "./contents/logs/.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": "true",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "Elmah": {
    "Email": {
      "MailSender": "",
      "MailRecipient": "",
      "MailSubjectFormat": "",
      "SmtpServer": ""
    }
  }
}